/* THEME MAPPING */
.base__accordions {
  margin: 30px 0;
}
@media (max-width: 991px) {
  .base__accordions {
    margin: 20px 0;
  }
}
.base__accordions .accordion-item {
  border: 1px solid #e3dcc9;
  border-radius: 5px;
  margin-bottom: 20px;
}
.base__accordions .accordion-item h4 {
  cursor: pointer;
  display: block;
  font-size: 18px;
  font-weight: 600;
  line-height: 32px;
  margin: 0;
  padding: 20px 80px 20px 20px;
  position: relative;
  text-transform: none;
}
.base__accordions .accordion-item h4::after {
  border-radius: 100%;
  color: #EFBE74;
  content: "\e90d";
  font-family: icomoon;
  font-size: 25px;
  height: 1.5em;
  line-height: 1.5em;
  position: absolute;
  right: 20px;
  text-align: center;
  top: 50%;
  transform-origin: 50% 25%;
  width: 1.5em;
  -moz-transform: translate(0, -50%);
  -o-transform: translate(0, -50%);
  -ms-transform: translate(0, -50%);
  -webkit-transform: translate(0, -50%);
  transform: translate(0, -50%);
}
.base__accordions .accordion-item h4.open {
  background: #13314B;
  color: #fff;
}
.base__accordions .accordion-item h4.open::after {
  color: #fff;
  content: "\e90c";
  line-height: 1.3em;
}
.base__accordions .accordion-item h4.open + div {
  padding: 20px;
}
.base__accordions .accordion-item h4 + div {
  font-size: 24px;
  line-height: 1.5em;
  margin: 0;
  max-height: 0;
  overflow: hidden;
  padding: 0 20px;
  -webkit-transition: max-height 0.3s cubic-bezier(0, 0, 0.2, 1), padding 0.4s cubic-bezier(0, 0, 0.2, 1);
  -moz-transition: max-height 0.3s cubic-bezier(0, 0, 0.2, 1), padding 0.4s cubic-bezier(0, 0, 0.2, 1);
  -ms-transition: max-height 0.3s cubic-bezier(0, 0, 0.2, 1), padding 0.4s cubic-bezier(0, 0, 0.2, 1);
  -o-transition: max-height 0.3s cubic-bezier(0, 0, 0.2, 1), padding 0.4s cubic-bezier(0, 0, 0.2, 1);
  transition: max-height 0.3s cubic-bezier(0, 0, 0.2, 1), padding 0.4s cubic-bezier(0, 0, 0.2, 1);
}
@media print {
  .base__accordions .accordion-item h4 + div {
    max-height: none !important;
  }
}
.base__accordions .accordion-item h4 p:last-child {
  margin-bottom: 0;
}

.facts {
  display: grid;
  grid: auto/40% 1fr;
  gap: 20px;
}
@media (max-width: 767px) {
  .facts {
    grid: auto/1fr;
  }
}
.facts .fact-card {
  border: 1px solid #f4f1e9;
  border-top: 4px solid #EBA030;
  border-radius: 5px;
  padding: 20px;
  text-align: center;
}
.facts .fact-card .stat {
  display: block;
  font-size: 72px;
  font-weight: 800;
  margin-bottom: 20px;
}
.facts .fact-card .title {
  font-size: 16px;
}

.base__text-card {
  height: 100%;
}
.base__text-card .inner {
  border-radius: 5px;
  box-shadow: 10px 10px 0px rgba(0, 0, 0, 0.1);
  height: 100%;
  padding: 30px 30px 50px;
}
.base__text-card .inner .heading {
  border-bottom: 2px solid;
  padding-bottom: 20px;
}
.base__text-card .inner p:last-child {
  margin-bottom: 0;
}
.base__text-card.primary .inner {
  background: #1f517d;
  color: #fff;
}
.base__text-card.primary .inner .heading {
  border-color: #EFBE74;
}
.base__text-card.primary-lt .inner {
  background: #d2dce5;
  color: #000;
}
.base__text-card.primary-lt .inner .heading {
  border-color: #13314B;
}
.base__text-card.primary-dk .inner {
  background: #13314B;
  color: #fff;
}
.base__text-card.primary-dk .inner .heading {
  border-color: #d2dce5;
}
.base__text-card.secondary .inner {
  background: #EBA030;
  color: #000;
}
.base__text-card.secondary .inner .heading {
  border-color: #9a6100;
}
.base__text-card.tertiary .inner {
  background: #e3dcc9;
  color: #000;
}
.base__text-card.tertiary .inner .heading {
  border-color: #888479;
}
.base__text-card.gray .inner {
  background: #f4f4f4;
  color: #000;
}
.base__text-card.gray .inner .heading {
  border-color: #d2dce5;
}
.base__text-card.black .inner {
  background: #000;
  color: #fff;
}
.base__text-card.black .inner .heading {
  border-color: #EFBE74;
}
.base__text-card.white .inner {
  background: #fff;
  color: #000;
}
.base__text-card.white .inner .heading {
  border-color: #EFBE74;
}
.base__text-card.bordered .inner {
  background: #fff;
  border: 2px solid #EBA030;
  color: #000;
}
.base__text-card.bordered .inner .heading {
  border-color: #EFBE74;
}

.base__layout.one .text-card .inner {
  padding: 90px 30px;
  text-align: center;
}
@media (max-width: 991px) {
  .base__layout.one .text-card .inner {
    padding: 30px;
  }
}
@media (min-width: 1200px) {
  .base__layout.one .text-card .inner .blurb {
    display: block;
    margin: 0 auto;
    max-width: 80%;
  }
}

.hero-wrap {
  margin-bottom: 50px;
}
@media (max-width: 991px) {
  .hero-wrap {
    margin-bottom: 20px;
  }
}

.base__hero {
  background: #0C2032;
  position: relative;
}
.base__hero.has-img {
  border-bottom: none;
  margin-bottom: 0;
}
.base__hero.has-img .img {
  position: relative;
}
.base__hero.has-img .img::before {
  background: rgba(0, 0, 0, 0.5);
  content: "";
  height: 100%;
  left: 0;
  position: absolute;
  top: 0;
  width: 100%;
  z-index: 1;
}
.base__hero.has-img .img img {
  aspect-ratio: 2.5/1;
  display: block;
  object-fit: cover;
  width: 100%;
}
@media (max-width: 767px) {
  .base__hero.has-img .img img {
    aspect-ratio: 2.5/3;
  }
}
@media (max-width: 480px) {
  .base__hero.has-img .img img {
    aspect-ratio: 2.5/4;
  }
}
@media (min-width: 768px) and (max-width: 991px) {
  .base__hero.has-img .img img {
    aspect-ratio: 3/2;
  }
}
@media (min-width: 1400px) {
  .base__hero.has-img .img img {
    aspect-ratio: 3/1;
    object-position: 0% 20%;
  }
}
.base__hero.has-img .img + .blurb {
  bottom: 60px;
  display: inline;
  position: absolute;
  width: 100%;
  z-index: 2;
}
@media (max-width: 991px) {
  .base__hero.has-img .img + .blurb {
    bottom: 0;
    display: block;
    padding: 30px 20px;
  }
}
.base__hero.has-video .img::before {
  background: rgba(0, 0, 0, 0.7) !important;
}
.base__hero.has-video .img img {
  aspect-ratio: 2/1;
  opacity: 0;
}
@media (max-width: 767px) {
  .base__hero.has-video .img img {
    aspect-ratio: 2/3;
  }
}
@media (min-width: 1200px) {
  .base__hero.has-video .img img {
    aspect-ratio: 5/2;
  }
}
@media (max-width: 991px) {
  .base__hero.has-video .img img {
    opacity: 1;
  }
}
.base__hero.has-video .video {
  height: 100%;
  left: 0;
  overflow: hidden;
  position: absolute;
  top: 0;
  width: 100%;
}
@media (max-width: 991px) {
  .base__hero.has-video .video {
    display: none;
  }
}
.base__hero:not(.has-img) {
  background: #0C2032;
  color: #fff;
  overflow: hidden;
  padding: 50px 0;
  position: relative;
}
@media (max-width: 767px) {
  .base__hero:not(.has-img) {
    padding: 30px 0;
  }
}
@media print {
  .base__hero:not(.has-img) {
    padding: 30px 0;
  }
}
.base__hero .blurb {
  max-width: 800px;
}
.base__hero .blurb h1 {
  color: #fff;
  font-family: "Roboto Condensed", sans-serif;
  font-size: 60px;
  line-height: 1em;
}
.base__hero .blurb p {
  color: #fff;
  font-size: 18px;
}
.base__hero .blurb p:last-child {
  margin: 0;
}
.base__hero + .crumbs {
  color: #3e3d3c;
  margin: 20px 0 30px;
}
.base__hero + .crumbs span {
  color: #d2dce5;
}
.base__hero + .crumbs a {
  color: #1f517d;
}
.base__hero + .crumbs a:hover, .base__hero + .crumbs a:focus {
  color: #d2dce5;
}

.full-width-cta {
  background-size: cover;
  padding: 30px;
  position: relative;
}
.full-width-cta.has-bg {
  padding: 100px 30px;
}
.full-width-cta.has-bgimg {
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  padding: 100px 30px;
}
.full-width-cta.has-bgimg .blurb.left .inner, .full-width-cta.has-bgimg .blurb.right .inner {
  background: #fff;
  color: #000;
  padding: 30px;
  text-align: left;
}
@media (min-width: 1200px) {
  .full-width-cta.has-bgimg .blurb.left .inner, .full-width-cta.has-bgimg .blurb.right .inner {
    width: 33%;
  }
}
.full-width-cta.has-bgimg .blurb.left .inner h2, .full-width-cta.has-bgimg .blurb.right .inner h2 {
  text-align: left;
}
.full-width-cta.has-bgimg .blurb .inner {
  color: #fff;
  margin: 0 auto;
  text-align: center;
}
.full-width-cta.has-bgimg .blurb .inner h2 {
  text-align: center;
}
.full-width-cta .blurb {
  width: 100%;
  z-index: 2;
}
.full-width-cta .blurb.right .inner {
  float: right;
}
.full-width-cta .blurb.left .inner {
  float: left;
}
.full-width-cta .blurb .inner {
  margin: 0 auto;
  text-align: center;
}
@media (min-width: 1200px) {
  .full-width-cta .blurb .inner {
    width: 60%;
  }
}
.full-width-cta .blurb .inner .subtitle {
  font-size: 14px;
  font-weight: 700;
  text-transform: uppercase;
  margin-bottom: 10px;
}