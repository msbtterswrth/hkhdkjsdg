/*CSS ANIMATIONS*/
/*SPACING*/
.facts {
  display: grid;
  grid: auto/40% 1fr;
  gap: 20px;
}
.facts .fact-card {
  border: 1px solid #eeeadf;
  border-radius: 5px;
  padding: 20px;
  text-align: center;
}
.facts .fact-card .stat {
  display: block;
  font-size: 72px;
  font-weight: 800;
  margin-bottom: 20px;
}
.facts .fact-card .title {
  font-size: 16px;
}