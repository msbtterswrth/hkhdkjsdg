*,
::before,
::after {
  box-sizing: border-box;
}

.clearfix:before,
.clearfix:after,
.container:before,
.container:after,
.container-fluid:before,
.container-fluid:after,
.row:before,
.row:after,
.nav:before,
.nav:after {
  display: table;
  content: " ";
}

.clearfix:after,
.container:after,
.container-fluid:after,
.row:after,
.nav:after {
  clear: both;
}

.site-wrap img {
  max-width: 100%;
}
.site-wrap .container {
  margin: 0 auto;
  padding: 0 20px;
  position: relative;
}
