  padding: 0;
  width: auto !important;
}
.site-wrap .embed-responsive {
  position: relative;
  display: block;
  width: 100%;
  padding: 0;
  overflow: hidden;
}
.site-wrap .embed-responsive::before {
  display: block;
  content: "";
}
