.grid {
  display: grid;
  gap: 30px;
  grid-template-rows: auto;
  align-items: stretch;
  justify-items: stretch;
}
.grid::before, .grid::after {
  display: none !important;
}
.grid.no-gutter {
  gap: 0;
}
.grid.normal {
  gap: 30px;
}
.grid.lg-gutter {
  gap: 50px;
}
@media (max-width: 991px) {
  .grid.lg-gutter {
    gap: 30px;
  }
}
.grid.one {
  grid-template-columns: repeat(1, 1fr);
}
.grid.two {
  grid-template-columns: repeat(2, 1fr);
}
@media (max-width: 767px) {
