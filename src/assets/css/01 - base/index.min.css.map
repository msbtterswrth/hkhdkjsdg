  padding-top: 56.25%;
}
.site-wrap .embed-responsive .embed-responsive-item,
.site-wrap .embed-responsive embed,
.site-wrap .embed-responsive iframe,
.site-wrap .embed-responsive object,
.site-wrap .embed-responsive video {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border: 0;
}
.site-wrap .embed-responsive .flush {
  margin: 0 !important;
}
